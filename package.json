{
  "name": "wedding-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "wrangler pages dev --compatibility-date=2024-11-01 -- npm run dev",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "db:migrate:local": "wrangler d1 migrations apply wedding-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply wedding-db --remote",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "jose": "^6.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241113.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wrangler": "^3.91.0"
  }
}
